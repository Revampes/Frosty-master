val ItemStack.metadata: Int get() {
  if (item in glassPanes) return glassPanes.indexOf(item)
  return 0
}

inline fun Terminal.mapSlots(
  items: List<ItemStack?>,
  range: List<Int>,
  glassPane: Boolean,
  function: (ItemStack) -> Int,
): List<Int>? {
    return range
        .mapNotNull { if (it in items.indices) items[it] else null }
        .filter { it.item != Items.AIR && ( !glassPane || it.item in glassPanes) }
        .takeIf { it.size == range.size }
        ?.map(function)
}


fun rectSlots(
    x1: Int,
    y1: Int,
    x2: Int,
    y2: Int,
) = buildList {
    (y1..y2).forEach { y ->
        (x1..x2).forEach { x ->
            add(x + y * 9)
        }
    }
}

fun distance(i1: Int, i2: Int): Int {
  val dx = (i1.mod(9) - i2.mod(9)).absoluteValue
  val dy = (i1 / 9 - i2 / 9).absoluteValue
  return dx * dx + dy * dy
}

fun getOrderedClicks(drawn: List<Terminal.SlotRenderInfo>, from: Int, toClick: (Terminal.SlotRenderInfo) -> Boolean): List<Int> {
  val drawn = drawn.map { toClick(it) }.toMutableList()
  var from = from
  return buildList {
    while (true) {
      val (i, info, click) =  drawn
        .mapIndexed { i, click -> Triple(i, click, distance(i, from)) }
        .filter { (_, click, _) -> click }
        .minByOrNull { (_, _, x) -> x } ?: return@buildList
      from = i
      add(i)
      add(i)
      drawn[i] = false
    }
  }
}

